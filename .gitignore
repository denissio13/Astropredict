```gitignore
# Compiled and binary files
*.pyc
__pycache__/

# Dependencies
.venv/
venv/
node_modules/

# Logs and temporary files
*.log
*.tmp
*.swp

# Environment files
.env
.env.local
*.env.*

# Editors and IDE
.vscode/
.idea/

# Coverage reports
.coverage
coverage/
htmlcov/

# Build artifacts
dist/
build/
target/
*.o
*.obj
*.exe
*.dll
*.so
*.a
*.out

# System files
.DS_Store
Thumbs.db

# Cache directories
.mypy_cache/
.pytest_cache/
.gradle/
```